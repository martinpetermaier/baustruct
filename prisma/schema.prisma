generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Mandanten ───────────────────────────────────────────────

model Company {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name             String   @db.VarChar(255)
  slug             String   @unique @db.VarChar(100)
  subscriptionPlan String   @default("free") @map("subscription_plan") @db.VarChar(50)
  documentCountMonth Int    @default(0) @map("document_count_month")
  erpType          String?  @map("erp_type") @db.VarChar(50)
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt        DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  users          User[]
  projects       Project[]
  suppliers      Supplier[]
  products       Product[]
  purchaseOrders PurchaseOrder[]
  deliveryNotes  DeliveryNote[]
  invoices       Invoice[]
  auditLogs      AuditLog[]

  @@map("companies")
}

// ─── Users ───────────────────────────────────────────────────

model User {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId    String   @map("company_id") @db.Uuid
  email        String   @unique @db.VarChar(255)
  name         String   @db.VarChar(255)
  role         String   @db.VarChar(50) // polier | einkauf | buchhaltung | admin
  passwordHash String?  @map("password_hash") @db.VarChar(255)
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz()

  company               Company        @relation(fields: [companyId], references: [id])
  managedProjects       Project[]      @relation("ProjectManager")
  createdPurchaseOrders PurchaseOrder[] @relation("POCreatedBy")
  approvedPurchaseOrders PurchaseOrder[] @relation("POApprovedBy")
  confirmedDeliveryNotes DeliveryNote[] @relation("DNConfirmedBy")
  uploadedAttachments   DeliveryNoteAttachment[] @relation("AttachmentUploader")
  auditLogs             AuditLog[]

  @@index([companyId])
  @@map("users")
}

// ─── Baustellen ──────────────────────────────────────────────

model Project {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId        String    @map("company_id") @db.Uuid
  name             String    @db.VarChar(255)
  code             String?   @db.VarChar(50)
  address          String?
  status           String    @default("active") @db.VarChar(50)
  budget           Decimal?  @db.Decimal(15, 2)
  startDate        DateTime? @map("start_date") @db.Date
  endDate          DateTime? @map("end_date") @db.Date
  projectManagerId String?   @map("project_manager_id") @db.Uuid
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz()

  company        Company        @relation(fields: [companyId], references: [id])
  projectManager User?          @relation("ProjectManager", fields: [projectManagerId], references: [id])
  purchaseOrders PurchaseOrder[]
  deliveryNotes  DeliveryNote[]

  @@index([companyId])
  @@map("projects")
}

// ─── Lieferanten ─────────────────────────────────────────────

model Supplier {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId        String   @map("company_id") @db.Uuid
  name             String   @db.VarChar(255)
  email            String?  @db.VarChar(255)
  phone            String?  @db.VarChar(50)
  address          String?
  taxId            String?  @map("tax_id") @db.VarChar(50)
  iban             String?  @db.VarChar(50)
  paymentTermsDays Int      @default(30) @map("payment_terms_days")
  skontoDays       Int?     @map("skonto_days")
  skontoPercent    Decimal? @map("skonto_percent") @db.Decimal(5, 2)
  isActive         Boolean  @default(true) @map("is_active")
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz()

  company        Company        @relation(fields: [companyId], references: [id])
  products       Product[]
  purchaseOrders PurchaseOrder[]
  deliveryNotes  DeliveryNote[]
  invoices       Invoice[]

  @@index([companyId])
  @@map("suppliers")
}

// ─── Produktkatalog ──────────────────────────────────────────

model Product {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId   String   @map("company_id") @db.Uuid
  supplierId  String?  @map("supplier_id") @db.Uuid
  name        String   @db.VarChar(255)
  description String?
  unit        String   @db.VarChar(50)
  unitPrice   Decimal? @map("unit_price") @db.Decimal(12, 4)
  currency    String   @default("EUR") @db.VarChar(3)
  category    String?  @db.VarChar(100)
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz()

  company            Company             @relation(fields: [companyId], references: [id])
  supplier           Supplier?           @relation(fields: [supplierId], references: [id])
  purchaseOrderItems PurchaseOrderItem[]
  deliveryNoteItems  DeliveryNoteItem[]

  @@index([companyId])
  @@map("products")
}

// ─── Bestellungen ────────────────────────────────────────────

model PurchaseOrder {
  id                    String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId             String    @map("company_id") @db.Uuid
  projectId             String    @map("project_id") @db.Uuid
  supplierId            String    @map("supplier_id") @db.Uuid
  orderNumber           String    @unique @map("order_number") @db.VarChar(100)
  status                String    @default("draft") @db.VarChar(50)
  createdById           String    @map("created_by") @db.Uuid
  approvedById          String?   @map("approved_by") @db.Uuid
  requestedDeliveryDate DateTime? @map("requested_delivery_date") @db.Date
  notes                 String?
  totalNet              Decimal?  @map("total_net") @db.Decimal(15, 2)
  totalVat              Decimal?  @map("total_vat") @db.Decimal(15, 2)
  totalGross            Decimal?  @map("total_gross") @db.Decimal(15, 2)
  createdAt             DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt             DateTime  @updatedAt @map("updated_at") @db.Timestamptz()

  company       Company             @relation(fields: [companyId], references: [id])
  project       Project             @relation(fields: [projectId], references: [id])
  supplier      Supplier            @relation(fields: [supplierId], references: [id])
  createdBy     User                @relation("POCreatedBy", fields: [createdById], references: [id])
  approvedBy    User?               @relation("POApprovedBy", fields: [approvedById], references: [id])
  items         PurchaseOrderItem[]
  deliveryNotes DeliveryNote[]
  invoiceLinks  InvoicePurchaseOrderLink[]

  @@index([companyId])
  @@index([projectId])
  @@index([status])
  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  purchaseOrderId String   @map("purchase_order_id") @db.Uuid
  productId       String?  @map("product_id") @db.Uuid
  description     String?
  quantity        Decimal  @db.Decimal(12, 4)
  unit            String   @db.VarChar(50)
  unitPrice       Decimal  @map("unit_price") @db.Decimal(12, 4)
  vatRate         Decimal  @default(19.00) @map("vat_rate") @db.Decimal(5, 2)
  totalNet        Decimal? @map("total_net") @db.Decimal(15, 2)
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz()

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  product       Product?      @relation(fields: [productId], references: [id])

  @@map("purchase_order_items")
}

// ─── Lieferscheine ───────────────────────────────────────────

model DeliveryNote {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId       String    @map("company_id") @db.Uuid
  projectId       String    @map("project_id") @db.Uuid
  supplierId      String    @map("supplier_id") @db.Uuid
  purchaseOrderId String?   @map("purchase_order_id") @db.Uuid
  deliveryNumber  String?   @map("delivery_number") @db.VarChar(100)
  status          String    @default("pending") @db.VarChar(50)
  deliveryDate    DateTime  @map("delivery_date") @db.Date
  confirmedById   String?   @map("confirmed_by") @db.Uuid
  confirmedAt     DateTime? @map("confirmed_at") @db.Timestamptz()
  notes           String?
  rawText         String?   @map("raw_text")
  aiConfidence    Decimal?  @map("ai_confidence") @db.Decimal(5, 2)
  aiParsedAt      DateTime? @map("ai_parsed_at") @db.Timestamptz()
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz()

  company       Company                @relation(fields: [companyId], references: [id])
  project       Project                @relation(fields: [projectId], references: [id])
  supplier      Supplier               @relation(fields: [supplierId], references: [id])
  purchaseOrder PurchaseOrder?         @relation(fields: [purchaseOrderId], references: [id])
  confirmedBy   User?                  @relation("DNConfirmedBy", fields: [confirmedById], references: [id])
  items         DeliveryNoteItem[]
  attachments   DeliveryNoteAttachment[]
  invoiceLinks  InvoicePurchaseOrderLink[]

  @@index([companyId])
  @@index([projectId])
  @@index([status])
  @@map("delivery_notes")
}

model DeliveryNoteItem {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  deliveryNoteId    String   @map("delivery_note_id") @db.Uuid
  productId         String?  @map("product_id") @db.Uuid
  description       String
  quantityDelivered Decimal  @map("quantity_delivered") @db.Decimal(12, 4)
  quantityOrdered   Decimal? @map("quantity_ordered") @db.Decimal(12, 4)
  unit              String?  @db.VarChar(50)
  unitPrice         Decimal? @map("unit_price") @db.Decimal(12, 4)
  deviationFlag     Boolean  @default(false) @map("deviation_flag")
  deviationNote     String?  @map("deviation_note")

  deliveryNote DeliveryNote  @relation(fields: [deliveryNoteId], references: [id], onDelete: Cascade)
  product      Product?      @relation(fields: [productId], references: [id])
  invoiceItems InvoiceItem[]

  @@map("delivery_note_items")
}

model DeliveryNoteAttachment {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  deliveryNoteId String   @map("delivery_note_id") @db.Uuid
  fileUrl        String   @map("file_url")
  fileType       String?  @map("file_type") @db.VarChar(50)
  fileName       String?  @map("file_name") @db.VarChar(255)
  uploadedById   String?  @map("uploaded_by") @db.Uuid
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz()

  deliveryNote DeliveryNote @relation(fields: [deliveryNoteId], references: [id], onDelete: Cascade)
  uploadedBy   User?        @relation("AttachmentUploader", fields: [uploadedById], references: [id])

  @@map("delivery_note_attachments")
}

// ─── Rechnungen ──────────────────────────────────────────────

model Invoice {
  id                   String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId            String    @map("company_id") @db.Uuid
  supplierId           String?   @map("supplier_id") @db.Uuid
  invoiceNumber        String?   @map("invoice_number") @db.VarChar(100)
  status               String    @default("received") @db.VarChar(50)
  invoiceDate          DateTime  @map("invoice_date") @db.Date
  dueDate              DateTime? @map("due_date") @db.Date
  paymentDate          DateTime? @map("payment_date") @db.Date
  totalNet             Decimal   @map("total_net") @db.Decimal(15, 2)
  totalVat             Decimal   @map("total_vat") @db.Decimal(15, 2)
  totalGross           Decimal   @map("total_gross") @db.Decimal(15, 2)
  currency             String    @default("EUR") @db.VarChar(3)
  threeWayMatchStatus  String?   @map("three_way_match_status") @db.VarChar(50)
  matchConfidence      Decimal?  @map("match_confidence") @db.Decimal(5, 2)
  rawText              String?   @map("raw_text")
  aiParsedAt           DateTime? @map("ai_parsed_at") @db.Timestamptz()
  aiBookingSuggestion  Json?     @map("ai_booking_suggestion")
  skontoAmount         Decimal?  @map("skonto_amount") @db.Decimal(15, 2)
  skontoDeadline       DateTime? @map("skonto_deadline") @db.Date
  erpBookingCode       String?   @map("erp_booking_code") @db.VarChar(100)
  erpExportedAt        DateTime? @map("erp_exported_at") @db.Timestamptz()
  fileUrl              String?   @map("file_url")
  createdAt            DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt            DateTime  @updatedAt @map("updated_at") @db.Timestamptz()

  company      Company                    @relation(fields: [companyId], references: [id])
  supplier     Supplier?                  @relation(fields: [supplierId], references: [id])
  items        InvoiceItem[]
  orderLinks   InvoicePurchaseOrderLink[]

  @@index([companyId, status])
  @@index([dueDate])
  @@map("invoices")
}

model InvoiceItem {
  id                   String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  invoiceId            String   @map("invoice_id") @db.Uuid
  deliveryNoteItemId   String?  @map("delivery_note_item_id") @db.Uuid
  description          String
  quantity             Decimal  @db.Decimal(12, 4)
  unit                 String?  @db.VarChar(50)
  unitPrice            Decimal  @map("unit_price") @db.Decimal(12, 4)
  vatRate              Decimal  @default(19.00) @map("vat_rate") @db.Decimal(5, 2)
  totalNet             Decimal? @map("total_net") @db.Decimal(15, 2)
  deviationFlag        Boolean  @default(false) @map("deviation_flag")

  invoice          Invoice           @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  deliveryNoteItem DeliveryNoteItem? @relation(fields: [deliveryNoteItemId], references: [id])

  @@map("invoice_items")
}

// ─── 3-Way-Match Link ────────────────────────────────────────

model InvoicePurchaseOrderLink {
  invoiceId       String   @map("invoice_id") @db.Uuid
  purchaseOrderId String   @map("purchase_order_id") @db.Uuid
  deliveryNoteId  String?  @map("delivery_note_id") @db.Uuid
  matchedAt       DateTime @default(now()) @map("matched_at") @db.Timestamptz()
  matchedBy       String?  @map("matched_by") @db.VarChar(50) // ai | manual

  invoice       Invoice       @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])
  deliveryNote  DeliveryNote? @relation(fields: [deliveryNoteId], references: [id])

  @@id([invoiceId, purchaseOrderId])
  @@map("invoice_purchase_order_links")
}

// ─── Audit ───────────────────────────────────────────────────

model AuditLog {
  id         BigInt   @id @default(autoincrement())
  companyId  String   @map("company_id") @db.Uuid
  userId     String?  @map("user_id") @db.Uuid
  entityType String   @map("entity_type") @db.VarChar(100)
  entityId   String   @map("entity_id") @db.Uuid
  action     String   @db.VarChar(50)
  changes    Json?
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz()

  company Company @relation(fields: [companyId], references: [id])
  user    User?   @relation(fields: [userId], references: [id])

  @@index([entityType, entityId])
  @@map("audit_log")
}
